---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import StageTimeline from '../../components/StageTimeline.astro';
import { getCollection } from 'astro:content';
import { stages, getStage } from '../../lib/stages';

export function getStaticPaths() {
  return stages.map(stage => ({
    params: { stage: stage.id },
    props: { stageInfo: stage },
  }));
}

const { stageInfo } = Astro.props;
const allPosts = await getCollection('blog');
const stagePosts = allPosts
  .filter(p => p.data.stage === stageInfo.id)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const stageIndex = stages.findIndex(s => s.id === stageInfo.id);
const prevStage = stageIndex > 0 ? stages[stageIndex - 1] : null;
const nextStage = stageIndex < stages.length - 1 ? stages[stageIndex + 1] : null;
---

<BaseLayout
  title={`${stageInfo.label}の記事一覧`}
  description={`${stageInfo.label}のママの悩みに寄り添う記事一覧。${stageInfo.description}`}
>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <!-- Breadcrumb -->
    <nav class="text-xs text-gray-400 mb-6">
      <a href="/" class="hover:text-[var(--color-primary)]">ホーム</a>
      <span class="mx-1">/</span>
      <a href="/stages" class="hover:text-[var(--color-primary)]">ステージ一覧</a>
      <span class="mx-1">/</span>
      <span class="text-gray-500">{stageInfo.shortLabel}</span>
    </nav>

    <!-- Stage Header -->
    <div class="bg-white rounded-xl shadow-sm p-8 mb-8 text-center">
      <div class="text-5xl mb-3">{stageInfo.emoji}</div>
      <h1 class="text-2xl md:text-3xl font-bold mb-2">{stageInfo.label}</h1>
      <p class="text-gray-500">{stageInfo.description}</p>
      <div class="flex justify-center gap-4 mt-6">
        {prevStage && (
          <a href={`/stage/${prevStage.id}`} class="text-sm text-gray-400 hover:text-[var(--color-primary)] transition">
            ← {prevStage.emoji} {prevStage.shortLabel}
          </a>
        )}
        {nextStage && (
          <a href={`/stage/${nextStage.id}`} class="text-sm text-gray-400 hover:text-[var(--color-primary)] transition">
            {nextStage.emoji} {nextStage.shortLabel} →
          </a>
        )}
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
      <!-- Articles -->
      <div class="lg:col-span-3">
        {stagePosts.length > 0 ? (
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            {stagePosts.map(post => (
              <ArticleCard
                title={post.data.title}
                description={post.data.description}
                slug={post.id}
                stage={post.data.stage}
                pubDate={post.data.pubDate}
                heroImage={post.data.heroImage}
              />
            ))}
          </div>
        ) : (
          <div class="bg-white rounded-xl p-8 text-center text-gray-400">
            <p>まだ記事がありません。順次追加していきます！</p>
          </div>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-1">
        <StageTimeline currentStage={stageInfo.id} />
      </aside>
    </div>
  </div>
</BaseLayout>
