---
import BaseLayout from '../layouts/BaseLayout.astro';
import { stages } from '../lib/stages';
---

<BaseLayout title="ページが見つかりません" description="お探しのページは見つかりませんでした。">
  <div class="max-w-3xl mx-auto px-4 py-16 text-center">
    <div class="bg-white rounded-2xl shadow-sm p-10">
      <p class="text-6xl mb-4">😢</p>
      <h1 class="text-2xl font-bold mb-3">ページが見つかりません</h1>
      <p class="text-gray-500 mb-8">お探しのページは移動または削除された可能性があります。</p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-10">
        <a href="/" class="inline-block bg-[var(--color-primary)] text-white px-6 py-3 rounded-full font-bold hover:opacity-90 transition">
          トップページへ
        </a>
        <a href="/stages" class="inline-block border-2 border-[var(--color-primary)] text-[var(--color-primary)] px-6 py-3 rounded-full font-bold hover:bg-[var(--color-primary)] hover:text-white transition">
          ステージ一覧へ
        </a>
      </div>

      <div class="text-left">
        <h2 class="text-lg font-bold mb-4 flex items-center gap-2">
          <span class="inline-block w-1.5 h-6 bg-[var(--color-primary)] rounded-full"></span>
          ステージから探す
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
          {stages.map(stage => (
            <a href={`/stage/${stage.id}`} class="flex items-center gap-2 bg-gray-50 rounded-lg p-3 hover:bg-[var(--color-warm)] transition text-sm">
              <span>{stage.emoji}</span>
              <span class="font-medium">{stage.shortLabel}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
