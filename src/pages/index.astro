---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { stages, stageGroups } from '../lib/stages';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const latestPosts = sortedPosts.slice(0, 6);
---

<BaseLayout title="ママのステージ" description="妊娠したかも？から小学校まで。あなたの「今」のステージに寄り添う育児情報サイト。年齢・時期別にママの悩みを解決します。">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-[var(--color-warm)] via-white to-[var(--color-primary-light)]">
    <div class="max-w-6xl mx-auto px-4 py-16 text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">
        あなたの<span style="color: var(--color-primary);">「今」</span>に寄り添う<br class="md:hidden" />育児ガイド
      </h1>
      <p class="text-gray-500 mb-8 max-w-lg mx-auto">
        妊娠したかも？という瞬間から小学校入学まで。<br />
        時期・年齢ごとの悩みにぴったりの情報をお届けします。
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 max-w-2xl mx-auto">
        {stageGroups.map(group => {
          const groupStages = stages.filter(s => s.group === group.id);
          return (
            <div class="bg-white rounded-xl p-4 shadow-sm hover:shadow-md transition">
              <div class="text-2xl mb-1">{group.emoji}</div>
              <div class="font-bold text-sm mb-2">{group.label}</div>
              <div class="space-y-1">
                {groupStages.map(s => (
                  <a href={`/stage/${s.id}`} class="block text-xs text-gray-500 hover:text-[var(--color-primary)] transition">
                    {s.emoji} {s.shortLabel}
                  </a>
                ))}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Latest -->
  <section class="max-w-6xl mx-auto px-4 py-12">
    <h2 class="text-xl font-bold mb-6">📝 最新記事</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {latestPosts.map(post => (
        <ArticleCard
          title={post.data.title}
          description={post.data.description}
          slug={post.id}
          stage={post.data.stage}
          pubDate={post.data.pubDate}
          heroImage={post.data.heroImage}
        />
      ))}
    </div>
  </section>

  <!-- By Group -->
  {stageGroups.map(group => {
    const groupStages = stages.filter(s => s.group === group.id);
    const groupPosts = sortedPosts.filter(p => groupStages.some(s => s.id === p.data.stage));
    if (groupPosts.length === 0) return null;
    return (
      <section class="max-w-6xl mx-auto px-4 py-8">
        <h2 class="text-xl font-bold mb-6">{group.emoji} {group.label}の記事</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {groupPosts.slice(0, 3).map(post => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              slug={post.id}
              stage={post.data.stage}
              pubDate={post.data.pubDate}
              heroImage={post.data.heroImage}
            />
          ))}
        </div>
      </section>
    );
  })}

  <!-- CTA -->
  <section class="bg-[var(--color-warm)] py-12 mt-8">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="text-xl font-bold mb-3">あなたの「ステージ」はどこですか？</h2>
      <p class="text-sm text-gray-500 mb-6">時期に合わせた情報で、育児の不安を少しでも軽くしたい。</p>
      <a href="/stages" class="inline-block bg-[var(--color-primary)] text-white px-8 py-3 rounded-full font-bold hover:bg-[var(--color-primary-dark)] transition">
        ステージ一覧を見る
      </a>
    </div>
  </section>
</BaseLayout>
