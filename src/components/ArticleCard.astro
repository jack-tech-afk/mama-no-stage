---
import { getStage } from '../lib/stages';

interface Props {
  title: string;
  description: string;
  slug: string;
  stage: string;
  pubDate: Date;
  heroImage?: string;
}

const { title, description, slug, stage, pubDate, heroImage } = Astro.props;
const stageInfo = getStage(stage);
const dateStr = pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });
---

<article class="bg-white rounded-xl shadow-sm hover:shadow-md transition-all duration-300 overflow-hidden group">
  <a href={`/${slug}`} class="block">
    {heroImage ? (
      <div class="aspect-video overflow-hidden bg-gray-100">
        <img src={heroImage} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
      </div>
    ) : (
      <div class="aspect-video bg-gradient-to-br from-[var(--color-warm)] to-[var(--color-primary-light)] flex items-center justify-center">
        <span class="text-4xl">{stageInfo?.emoji ?? '📝'}</span>
      </div>
    )}
    <div class="p-4">
      <div class="flex items-center gap-2 mb-2">
        {stageInfo && (
          <span class={`stage-badge ${stage}`}>{stageInfo.shortLabel}</span>
        )}
        <time class="text-xs text-gray-400" datetime={pubDate.toISOString()}>{dateStr}</time>
      </div>
      <h3 class="font-bold text-sm leading-snug mb-2 group-hover:text-[var(--color-primary)] transition line-clamp-2">{title}</h3>
      <p class="text-xs text-gray-500 line-clamp-2">{description}</p>
    </div>
  </a>
</article>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
