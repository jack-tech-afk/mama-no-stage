---
interface AffiliateItem {
  name: string;
  url: string;
  price?: string;
  description: string;
}

interface Props {
  items: AffiliateItem[];
  heading?: string;
}

const { items, heading = 'おすすめアイテム' } = Astro.props;
---

{items.length > 0 && (
  <div class="affiliate-box">
    <h3 class="text-lg font-bold mb-4 flex items-center gap-2">
      <span>✨</span>
      <span>{heading}</span>
    </h3>
    <div class="space-y-4">
      {items.map(item => (
        <div class="flex flex-col sm:flex-row sm:items-center gap-3 bg-white rounded-lg p-4 border border-gray-100">
          <div class="flex-1">
            <div class="font-bold text-sm">{item.name}</div>
            <p class="text-xs text-gray-500 mt-1">{item.description}</p>
            {item.price && <span class="text-xs font-medium text-[var(--color-primary)] mt-1 inline-block">{item.price}</span>}
          </div>
          <a
            href={item.url}
            target="_blank"
            rel="nofollow noopener sponsored"
            class="btn text-center text-sm shrink-0"
          >
            詳細を見る
          </a>
        </div>
      ))}
    </div>
    <p class="text-[10px] text-gray-400 mt-3">※価格は変更される場合があります。最新情報は各公式サイトでご確認ください。</p>
  </div>
)}
